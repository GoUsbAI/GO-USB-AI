{
  "name": "@go-usb-ai/remote",
  "version": "0.1.102",
  "private": false,
  "description": "Remote access runtime for GoUsbAi device registration, relay bridging, and service-managed connectivity.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Peiiii/go-usb-ai.git",
    "directory": "packages/go-usb-ai-remote"
  },
  "homepage": "https://github.com/Peiiii/go-usb-ai/tree/master/packages/go-usb-ai-remote",
  "keywords": [
    "go-usb-ai",
    "remote",
    "relay",
    "cli"
  ],
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts.sourcemap --clean --target es2022 --no-fixedExtension",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "prepublishOnly": "node ../../scripts/release/ensure-pnpm-publish.mjs"
  },
  "dependencies": {
    "@go-usb-ai/core": "workspace:*",
    "@go-usb-ai/kernel": "workspace:*",
    "@go-usb-ai/server": "workspace:*",
    "commander": "^12.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/ws": "^8.5.14",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
