{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@go-usb-ai-server/*": [
        "src/*"
      ],
      "@core/*": [
        "../go-usb-ai-core/src/*"
      ],
      "@go-usb-ai/core": [
        "../go-usb-ai-core/src/index.ts"
      ],
      "@go-usb-ai/kernel": [
        "../go-usb-ai-kernel/src/index.ts"
      ],
      "@go-usb-ai/shared": [
        "../go-usb-ai-shared/src/index.ts"
      ],
      "@kernel/*": [
        "../go-usb-ai-kernel/src/*"
      ],
      "@go-usb-ai/kernel/update-contract": [
        "../go-usb-ai-kernel/src/types/update-contract.types.ts"
      ],
      "@go-usb-ai/runtime": [
        "../go-usb-ai-runtime/src/index.ts"
      ],
      "@go-usb-ai/openclaw-compat": [
        "../go-usb-ai-openclaw-compat/src/index.ts"
      ],
      "@go-usb-ai/ncp": [
        "../ncp-packages/go-usb-ai-ncp/src/index.ts"
      ]
    }
  },
  "include": [
    "src"
  ]
}
