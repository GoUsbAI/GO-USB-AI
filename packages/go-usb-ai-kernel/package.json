{
  "name": "@go-usb-ai/kernel",
  "version": "0.1.14",
  "private": false,
  "description": "GoUsbAi product kernel skeleton for agents, tasks, sessions, context, tools, skills, providers, automation, and channels.",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./update-contract": {
      "development": "./src/types/update-contract.types.ts",
      "types": "./dist/types/update-contract.types.d.ts",
      "default": "./dist/types/update-contract.types.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/types/update-contract.types.ts --dts.sourcemap --clean --target es2022 --no-fixedExtension",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "test": "vitest run",
    "tsc": "tsc -p tsconfig.json",
    "prepublishOnly": "node ../../scripts/release/ensure-pnpm-publish.mjs"
  },
  "dependencies": {
    "@go-usb-ai/channel-extension-feishu": "workspace:*",
    "@go-usb-ai/channel-extension-weixin": "workspace:*",
    "@go-usb-ai/core": "workspace:*",
    "@go-usb-ai/mcp": "workspace:*",
    "@go-usb-ai/ncp-agent-runtime": "workspace:*",
    "@go-usb-ai/ncp-agent-runtime-next": "workspace:*",
    "@go-usb-ai/ncp-mcp": "workspace:*",
    "@go-usb-ai/ncp-toolkit": "workspace:*",
    "@go-usb-ai/go-usb-ai-ncp-runtime-http-client": "workspace:*",
    "@go-usb-ai/go-usb-ai-ncp-runtime-stdio-client": "workspace:*",
    "@go-usb-ai/openclaw-compat": "workspace:*",
    "@go-usb-ai/runtime": "workspace:*",
    "@go-usb-ai/shared": "workspace:*",
    "@go-usb-ai/ncp": "workspace:*",
    "rxjs": "^7.8.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
