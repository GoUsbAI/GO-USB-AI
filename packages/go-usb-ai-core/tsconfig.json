{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@core/*": ["./src/*"],
      "@go-usb-ai/shared": ["../go-usb-ai-shared/src/index.ts"],
      "@go-usb-ai/ncp": ["../ncp-packages/go-usb-ai-ncp/src/index.ts"],
      "@go-usb-ai/ncp/*": ["../ncp-packages/go-usb-ai-ncp/src/*"]
    }
  },
  "include": ["src"]
}
