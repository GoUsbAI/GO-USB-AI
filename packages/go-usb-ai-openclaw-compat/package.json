{
  "name": "@go-usb-ai/openclaw-compat",
  "version": "1.0.24",
  "private": false,
  "description": "OpenClaw plugin compatibility layer for GoUsbAi.",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts.sourcemap --clean --target es2022 --no-fixedExtension",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "test": "vitest",
    "prepublishOnly": "node ../../scripts/release/ensure-pnpm-publish.mjs"
  },
  "dependencies": {
    "@go-usb-ai/ncp": "workspace:*",
    "@go-usb-ai/ncp-toolkit": "workspace:*",
    "ajv": "^8.17.1",
    "jiti": "^1.21.7",
    "jszip": "^3.10.1",
    "tar": "^7.4.3"
  },
  "peerDependencies": {
    "@go-usb-ai/core": "workspace:*"
  },
  "devDependencies": {
    "@go-usb-ai/core": "workspace:*",
    "@types/node": "^20.17.6",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
