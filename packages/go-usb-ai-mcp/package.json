{
  "name": "@go-usb-ai/mcp",
  "version": "0.1.89",
  "private": false,
  "description": "Platform-level MCP registry, lifecycle, and diagnostics for GoUsbAi.",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts.sourcemap --clean --target es2022 --no-fixedExtension",
    "prepack": "pnpm run build",
    "lint": "cd ../.. && pnpm exec eslint packages/go-usb-ai-mcp --config eslint.config.mjs",
    "tsc": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "node ../../scripts/release/ensure-pnpm-publish.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@go-usb-ai/core": "workspace:*",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  }
}
