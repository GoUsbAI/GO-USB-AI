{
  "name": "@go-usb-ai/desktop",
  "version": "0.0.193",
  "private": true,
  "description": "GO-USB-AI desktop shell powered by Electron.",
  "author": "GO-USB-AI Team",
  "homepage": "https://github.com/Peiiii/go-usb-ai",
  "main": "dist/src/main.js",
  "license": "MIT",
  "scripts": {
    "bundle:build": "node scripts/update/services/build-product-bundle.service.mjs",
    "bundle:public-key": "node scripts/update/services/write-bundle-public-key.service.mjs",
    "bundle:public-key:ensure": "node scripts/update/services/ensure-bundle-public-key.service.mjs --output build/update-bundle-public.pem",
    "bundle:release-metadata": "node scripts/update/services/write-release-metadata.service.mjs",
    "bundle:minimum-launcher-version": "node scripts/update/services/print-minimum-launcher-version.service.mjs",
    "bundle:seed": "node scripts/update/services/prepare-seed-bundle.service.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "bundle:manifest": "node scripts/update/services/build-update-manifest.service.mjs",
    "package:windows-portable": "node scripts/package-windows-portable.mjs",
    "dev": "node scripts/ensure-runtime.mjs && pnpm build:main && GOUSB_AI_DESKTOP_RUNTIME_SCRIPT=../../packages/go-usb-ai/dist/cli/app/index.js env -u ELECTRON_RUN_AS_NODE electron .",
    "build": "pnpm build:main",
    "build:main": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json --outDir dist --noEmit false",
    "lint": "eslint \"src/**/*.ts\"",
    "tsc": "tsc -p tsconfig.json --noEmit",
    "pack": "node scripts/ensure-runtime.mjs && pnpm bundle:public-key:ensure && pnpm bundle:seed -- --channel stable && pnpm build:main && electron-builder --dir",
    "dist": "node scripts/ensure-runtime.mjs && pnpm bundle:public-key:ensure && pnpm bundle:seed -- --channel stable && pnpm build:main && electron-builder",
    "smoke": "pnpm build:main && node scripts/smoke-runtime.mjs",
    "smoke:update": "node scripts/smoke-product-update.mjs",
    "validation:dev-update": "node scripts/update/services/dev-update-validation.service.mjs",
    "validation:prepare-manual-update": "node scripts/prepare-manual-update-validation.mjs",
    "validation:serve-local-update": "node scripts/run-local-update-server.mjs"
  },
  "dependencies": {
    "@go-usb-ai/channel-extension-dingtalk": "workspace:*",
    "@go-usb-ai/channel-extension-discord": "workspace:*",
    "@go-usb-ai/channel-extension-email": "workspace:*",
    "@go-usb-ai/channel-extension-qq": "workspace:*",
    "@go-usb-ai/channel-extension-slack": "workspace:*",
    "@go-usb-ai/channel-extension-telegram": "workspace:*",
    "@go-usb-ai/channel-extension-wecom": "workspace:*",
    "@go-usb-ai/channel-extension-whatsapp": "workspace:*",
    "@go-usb-ai/core": "workspace:*",
    "@go-usb-ai/kernel": "workspace:*",
    "@go-usb-ai/openclaw-compat": "workspace:*",
    "@go-usb-ai/server": "workspace:*",
    "jszip": "^3.10.1",
    "go-usb-ai": "workspace:*"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/node": "^20.17.6",
    "electron": "^32.2.1",
    "electron-builder": "^25.1.8",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "io.go-usb-ai.desktop",
    "productName": "GO-USB-AI Desktop",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "build/icons/icon.png",
      "package.json",
      "!node_modules/electron/**"
    ],
    "extraResources": [
      {
        "from": "build/update-release-metadata.json",
        "to": "update/update-release-metadata.json"
      },
      {
        "from": "build/update-bundle-public.pem",
        "to": "update/update-bundle-public.pem"
      },
      {
        "from": "build/update/seed-product-bundle.zip",
        "to": "update/seed-product-bundle.zip"
      }
    ],
    "npmRebuild": false,
    "asar": true,
    "afterSign": "./scripts/electron-after-sign.cjs",
    "mac": {
      "icon": "build/icons/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "artifactName": "GO-USB-AI.Desktop-Setup-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GO-USB-AI Desktop",
      "uninstallDisplayName": "GO-USB-AI Desktop",
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico",
      "installerHeaderIcon": "build/icons/icon.ico"
    },
    "linux": {
      "artifactName": "go-usb-ai-desktop-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility"
    },
    "deb": {
      "packageName": "go-usb-ai-desktop",
      "maintainer": "GO-USB-AI Team",
      "priority": "optional",
      "packageCategory": "utility",
      "synopsis": "GO-USB-AI Desktop",
      "description": "GO-USB-AI desktop shell powered by Electron."
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Peiiii",
        "repo": "go-usb-ai"
      }
    ]
  }
}
